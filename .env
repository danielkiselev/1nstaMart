APP_NAME=1nstaMart
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack

MARKETPLACE_JSWARNING=true

ELASTICSEARCH_INDEX=products

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=1nstaMart_db
DB_USERNAME=${DB_USERNAME:-user1}
DB_PASSWORD=${DB_PASSWORD:-changeme}

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
SESSION_DRIVER=file
SESSION_LIFETIME=120
QUEUE_DRIVER=sync

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

BITMESSAGE_ENABLED=false
BITMESSAGE_ADDRESS=
BITMESSAGE_HOST=
BITMESSAGE_PORT=
BITMESSAGE_USER=
BITMESSAGE_PASSWORD=

BITCOIND_HOST=127.0.0.1
BITCOIND_PORT=8332
BITCOIND_USERNAME=${BITCOIND_USERNAME:-user1}
BITCOIND_PASSWORD=${BITCOIND_PASSWORD:-changeme}
BITCOIND_MINCONFIRMATIONS=2

MONERO_HOST=127.0.0.1
MONERO_PORT=18083
MONERO_USERNAME=${MONERO_USERNAME:-user1}
MONERO_PASSWORD=${MONERO_PASSWORD:-changeme}

YERB_HOST=127.0.0.1
YERB_PORT=15419
YERB_USERNAME=${YERB_USERNAME:-user1}
YERB_PASSWORD=${YERB_PASSWORD:-changeme}

RTM_HOST=127.0.0.1
RTM_PORT=10226
RTM_USERNAME=${RTM_USERNAME:-user1}
RTM_PASSWORD=${RTM_PASSWORD:-changeme}
